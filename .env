# N_INLET = indice do nó de entrada de vazão/pressão (se houver apenas uma entrada de vazão/pressão)
# INLET_FLOW = vazão de entrada
# INLET_PRESSURE = pressão de entrada
# INLET_FLOW_DICT = (str) dicionário onde as chaves são indices dos nós de entrada e os valores são as vazões de entrada
# INLET_PRESSURE_DICT = (str) dicionário onde as chaves são indices dos nós de entrada e os valores são as pressões de entrada
# INLET_FLOW_SIN_DICT = (str) dicionário que contém as constantes da função f(t) = A*sen(omega*t + theta) 
# INLET_FLOW_COS_DICT = (str) dicionário que contém as constantes da função g(t) = A*cos(omega*t + theta) 
N_INLET = 1
INLET_FLOW = 0.0000001
INLET_PRESSURE = 100
INLET_FLOW_DICT = '{"0": 1.0e-7, "175": 1.0e-6}'
INLET_PRESSURE_DICT = '{"0": 1.0e-7, "175": 1.0e-6}'
INLET_FLOW_SIN_DICT = '{"N_INLET": 1, "A": 0.1, "omega": 3, "theta": 0}'
INLET_FLOW_COS_DICT = '{"N_INLET": 176, "A": 0.01, "omega": 4, "theta": 0}'

# N_OUTLET = indice do nó de saida de vazão/pressão (se houver apenas uma saida de vazão/pressão)
# OUTLET = pressão/vazão de saida
N_OUTLET = 5
OUTLET = 0

# PIPE_AREA = área da seção tranversal dos canos
# VISCOSITY = viscosidade do fluido
# TIME_ANALYSIS = (str) dicionário da lista do tempo inicial, final e repartições (para funcionalidades que dependem de análise temporal)
PIPE_AREA = 0.00000025
VISCOSITY = 0.001
TIME_ANALYSIS = '{"t": [0, 10, 1000]}'